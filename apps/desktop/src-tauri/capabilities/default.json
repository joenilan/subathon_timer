{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    "core:window:allow-inner-size",
    "core:window:allow-scale-factor",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size"
  ]
}