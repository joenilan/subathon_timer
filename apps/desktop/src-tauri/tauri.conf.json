{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Subathon Timer",
  "mainBinaryName": "subathon-timer",
  "version": "0.9.1",
  "identifier": "com.dreadedzombie.subathon-timer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Subathon Timer",
        "width": 880,
        "height": 620,
        "minWidth": 520,
        "minHeight": 360,
        "resizable": true,
        "backgroundColor": "#090b10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "upgradeCode": "20aa997a-d017-5bc5-850c-69b7ae8029be"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
