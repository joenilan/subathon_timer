{
  "name": "subathon-timer-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "version:check": "node ./scripts/version.mjs check",
    "version:check-notes": "node ./scripts/version.mjs check-notes",
    "version:sync": "node ./scripts/version.mjs sync",
    "version:set": "node ./scripts/version.mjs set",
    "version:patch": "node ./scripts/version.mjs patch",
    "version:minor": "node ./scripts/version.mjs minor",
    "version:major": "node ./scripts/version.mjs major",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:clean": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "tauri:clean:release": "cargo clean --manifest-path src-tauri/Cargo.toml --release",
    "tauri:build:clean": "tauri build && cargo clean --manifest-path src-tauri/Cargo.toml --release"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@testing-library/react": "^16.3.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
